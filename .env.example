NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Production example: NEXT_PUBLIC_APP_URL=https://learnbuddy.your-university.edu
# Optional override for runtime hardening outside Vercel: production | preview | local.
LEARNBUDDY_DEPLOYMENT_ENV=local
AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgres://user:password@host/db?sslmode=require
# Optional Magic-Link abuse guard. Defaults: 5 requests per email per 15 minutes, then 15 minutes blocked.
LEARNBUDDY_AUTH_MAGIC_LINK_LIMIT=5
LEARNBUDDY_AUTH_MAGIC_LINK_WINDOW_MS=900000
LEARNBUDDY_AUTH_MAGIC_LINK_BLOCK_MS=900000
# Optional: set to "local" to force the JSON fallback even when DATABASE_URL exists.
LEARNBUDDY_REPOSITORY=postgres
# Optional: maximum material file upload size in bytes. Default is 26214400 (25 MiB).
LEARNBUDDY_MAX_UPLOAD_BYTES=26214400
# Optional retention window for pseudonymous learning signals. Default is 5 years.
# Course content and standalone archives follow config/retention-policy.json and are not auto-deleted.
LEARNBUDDY_RETENTION_YEARS=5
# Optional KI provider. Default without these values is the local scoped demo provider.
# Production-preferred path: LEARNBUDDY_AI_PROVIDER=learnordie-responses uses
# https://llm.learnordie.app/v1/responses. The proxy runs in this project,
# keeps the MiniMax upstream key server-side and exposes only a separate proxy token.
# Legacy fallback: LEARNBUDDY_AI_PROVIDER=openai-compatible for any /v1/chat/completions endpoint.
LEARNBUDDY_AI_PROVIDER=
LEARNORDIE_LLM_PROXY_BASE_URL=https://llm.learnordie.app
LEARNORDIE_LLM_PROXY_API_KEY=
LEARNORDIE_MINIMAX_API_KEY=
# Compatible legacy names are still supported:
LEARNBUDDY_LLM_PROXY_BASE_URL=https://llm.learnordie.app
LEARNBUDDY_LLM_PROXY_API_KEY=
MINIMAX_API_KEY=
# CTOX-compatible aliases are accepted only for migration/shared environments:
# CTOX_LLM_PROXY_BASE_URL=https://llm.ctox.dev
# CTOX_LLM_PROXY_API_KEY=ctox_llm_xxx
LEARNBUDDY_AI_BASE_URL=
LEARNBUDDY_AI_API_KEY=
LEARNBUDDY_AI_MODEL=
LEARNBUDDY_AI_TIMEOUT_MS=15000
# Optional Referenten-Assistent. Default ist der lokale Planungsagent.
# Set to "ai" to reuse the configured server-side AIProvider/Responses proxy.
LEARNBUDDY_LECTURER_ASSISTANT_PROVIDER=local
# Optional chat question moderation. Production should use "ai" with the server-side AI provider.
LEARNBUDDY_CHAT_MODERATION_PROVIDER=local
# Optional public chat question abuse guard. Defaults: 5 questions per anonymous key per lecture per 15 minutes.
LEARNBUDDY_CHAT_QUESTION_LIMIT_PER_WINDOW=5
# Question generation. Default is local deterministic review variants for local demos.
# Preview/production release gates require "ai" to synthesize material review variants through the server-side AI provider.
LEARNBUDDY_QUESTION_GENERATOR=
# Optional embedding provider. Default without these values is the local deterministic provider.
# Set LEARNBUDDY_EMBEDDING_PROVIDER=openai-compatible for any OpenAI-compatible /v1/embeddings endpoint.
# Use learnbuddy-local-hash-v1 for portable deterministic retrieval without an external embedding API.
LEARNBUDDY_EMBEDDING_PROVIDER=
LEARNBUDDY_EMBEDDING_BASE_URL=
LEARNBUDDY_EMBEDDING_API_KEY=
LEARNBUDDY_EMBEDDING_MODEL=
LEARNBUDDY_EMBEDDING_TIMEOUT_MS=15000
# OCR/vision provider for scanned PDF/PPTX/image materials.
# Local demos may leave this empty, but preview/production release gates require provider-backed scan support.
# Use "http" for a dedicated /v1/ocr service, or "openai-compatible" for a /v1/chat/completions vision endpoint.
LEARNBUDDY_OCR_PROVIDER=
LEARNBUDDY_OCR_BASE_URL=
LEARNBUDDY_OCR_API_KEY=
LEARNBUDDY_OCR_MODEL=
LEARNBUDDY_OCR_LANGUAGE=de
LEARNBUDDY_OCR_TIMEOUT_MS=20000
# Optional object storage. Default is local filesystem under .data/artifacts.
# vercel-blob uses @vercel/blob with BLOB_READ_WRITE_TOKEN or LEARNBUDDY_STORAGE_TOKEN.
# http is a portable self-hosting/mock adapter using PUT/GET /objects/:path behind the app proxy.
LEARNBUDDY_STORAGE_PROVIDER=
LEARNBUDDY_STORAGE_ACCESS=private
LEARNBUDDY_STORAGE_TOKEN=
LEARNBUDDY_STORAGE_ENDPOINT=
# Self-hosted object storage example: LEARNBUDDY_STORAGE_ENDPOINT=https://object-storage.your-university.edu
LEARNBUDDY_STORAGE_API_KEY=
LEARNBUDDY_STORAGE_DIR=.data/artifacts
LEARNBUDDY_STORAGE_TIMEOUT_MS=15000
# Optional portable job broker. Default is inline execution.
# http registers material/export jobs with a server-side external broker, then runs the existing handler.
# database queues material/export jobs in Postgres; run /api/jobs/worker or `npm run admin -- worker-once`.
LEARNBUDDY_JOB_PROVIDER=
LEARNBUDDY_JOB_ENDPOINT=
LEARNBUDDY_JOB_API_KEY=
LEARNBUDDY_JOB_TIMEOUT_MS=15000
LEARNBUDDY_WORKER_SECRET=
LEARNBUDDY_WORKER_APP_URL=
# Optional DB worker retry policy. Defaults: 3 attempts, 30000 ms exponential base delay.
LEARNBUDDY_WORKER_MAX_ATTEMPTS=3
LEARNBUDDY_WORKER_RETRY_BASE_MS=30000
# Optional Vercel Cron trigger. Vercel sends CRON_SECRET as Authorization: Bearer ...
CRON_SECRET=
LEARNBUDDY_WORKER_CRON_LIMIT=5
LEARNBUDDY_MAIL_PROVIDER=console
# Optional for provider-smoke mocks or self-hosted Resend-compatible gateways.
# If set, the runtime MailProvider uses the same endpoint; preview/production must not point to local/private hosts.
LEARNBUDDY_RESEND_BASE_URL=
RESEND_API_KEY=re_xxx
EMAIL_FROM=learnordie.app <noreply@your-university.edu>
# STT provider. Use mistral-voxtral with Mistral, or openai-compatible/self-hosted-vllm
# for a self-hosted endpoint exposing /v1/audio/transcriptions.
# self-hosted-vllm-realtime uses a vLLM/OpenAI-compatible /v1/realtime WebSocket endpoint
# for PCM16/WAV segments while keeping provider keys server-side.
LEARNBUDDY_STT_PROVIDER=
LEARNBUDDY_STT_BASE_URL=https://api.mistral.ai
LEARNBUDDY_STT_REALTIME_BASE_URL=
LEARNBUDDY_STT_MODEL=voxtral-mini-latest
LEARNBUDDY_STT_LANGUAGE=de
LEARNBUDDY_STT_CONTEXT_BIAS=
LEARNBUDDY_STT_TIMEOUT_MS=20000
MISTRAL_API_KEY=replace-when-stt-is-enabled
LEARNBUDDY_STT_API_KEY=
# Release gates:
# npm run typecheck
# npm run lint
# npm audit --audit-level=moderate
# npm run provider:smoke -- --profile production
# npm run test:e2e
# npm run admin -- preflight --profile production
# Deploy readiness before Vercel deploy:
# npm run deploy:readiness -- --environment preview --pull-vercel-env --scope metric-spaces-projects
LEARNBUDDY_DEPLOY_READINESS_ENVIRONMENT=preview
LEARNBUDDY_DEPLOY_READINESS_PULL_VERCEL_ENV=0
# Set to 1 only for portable self-hosting readiness using process.env.
LEARNBUDDY_DEPLOY_READINESS_SELF_HOST=0
# Local readiness is a process.env diagnostic path, not a Vercel target-env proof.
LEARNBUDDY_DEPLOY_READINESS_LOCAL=0
LEARNBUDDY_DEPLOY_READINESS_VERCEL_SCOPE=metric-spaces-projects
LEARNBUDDY_DEPLOY_READINESS_TIMEOUT_MS=20000
# Strict full gate after deploying and receiving a real Resend magic link:
# LEARNBUDDY_RELEASE_GATE_MAGIC_LINK=https://.../auth/magic?token=... npm run release:gate -- --mode full --pull-vercel-env --scope metric-spaces-projects --url https://<preview-or-production-url> --lecture-token gleitlagerung-demo --email referent@your-university.edu
# Self-hosting full gate: npm run release:gate -- --mode full --environment production --self-host --url https://<self-host-url> --lecture-token gleitlagerung-demo --email referent@your-university.edu
LEARNBUDDY_RELEASE_GATE_MODE=full
LEARNBUDDY_RELEASE_GATE_ENVIRONMENT=preview
LEARNBUDDY_RELEASE_GATE_PULL_VERCEL_ENV=0
# Set to 1 only when the full gate target is a self-hosted runtime using process.env.
LEARNBUDDY_RELEASE_GATE_SELF_HOST=0
# CI diagnostics may still use process.env deliberately, but that is not a self-hosting release target.
LEARNBUDDY_RELEASE_GATE_ALLOW_PROCESS_ENV=0
LEARNBUDDY_RELEASE_GATE_VERCEL_SCOPE=metric-spaces-projects
LEARNBUDDY_RELEASE_GATE_URL=
LEARNBUDDY_RELEASE_GATE_LECTURE_TOKEN=gleitlagerung-demo
LEARNBUDDY_RELEASE_GATE_EMAIL=referent@your-university.edu
LEARNBUDDY_RELEASE_GATE_MAGIC_LINK=
LEARNBUDDY_RELEASE_GATE_TIMEOUT_MS=120000
