{
  "name": "learnordie",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "admin": "node scripts/admin.mjs",
    "check:slide-engine-vendor": "node scripts/slide-engine-vendor-check.mjs",
    "deploy:readiness": "node scripts/deploy-readiness.mjs",
    "motion:contract": "node scripts/motion-design-contract.mjs",
    "provider:smoke": "node scripts/provider-smoke.mjs",
    "release:gate": "node scripts/release-gate.mjs",
    "scripts:check": "node scripts/script-syntax-check.mjs",
    "smoke:backup-restore": "node scripts/backup-restore-smoke.mjs",
    "smoke:live": "node scripts/live-smoke.mjs",
    "smoke:live-load": "node scripts/live-load-smoke.mjs",
    "smoke:self-host": "node scripts/self-host-smoke.mjs",
    "smoke:worker": "node scripts/worker-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "vendor:reveal-core": "node scripts/vendor-reveal-core.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:local": "playwright test --config playwright.local.config.ts",
    "test:slide-engine": "playwright test --config playwright.slide-engine.config.ts"
  },
  "dependencies": {
    "@learnordie/slide-engine": "file:packages/slide-engine",
    "@vercel/blob": "^2.4.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.3",
    "next": "^16.2.9",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.13.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "playwright": "^1.61.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15"
  }
}
